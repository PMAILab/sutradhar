# Server
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
# The frontend's own public URL, despite the name — not this API's own
# onrender.com URL. In prod, that's the Netlify site (Netlify proxies
# /api/* here server-to-server, see netlify.toml, so that's the only
# origin Supabase has allow-listed for redirects). Locally, set this to
# http://localhost:5173 (not blank) — Vite's dev proxy rewrites the Host
# header to its proxy target when forwarding, so req.get('host') reports
# localhost:4000 instead of localhost:5173 if this is left unset, which
# points the OAuth callback at the wrong origin and scopes the session
# cookie to a port the frontend's own requests never use.
APP_ORIGIN=http://localhost:5173
# production enables secure, sameSite:none session cookies (required as a
# fallback for anyone hitting this API directly instead of through the
# Netlify proxy); leave unset in local dev.
NODE_ENV=

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Google AI Studio)
GEMINI_API_KEY=

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
